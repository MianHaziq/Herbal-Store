# ─────────────────────────────────────────────────────────────────────
# Order delivery (server-side only — NOT exposed to the browser).
#
# The Google Apps Script Web App URL that receives orders and appends them
# to your Google Sheet. Used by app/api/order/route.ts.
#
# Local dev:  copy this file to ".env.local" and paste your URL below.
# Production: set this same variable in your host's dashboard
#             (Vercel → Project → Settings → Environment Variables).
# ─────────────────────────────────────────────────────────────────────
GOOGLE_SHEET_WEBHOOK_URL=
